    "import time\n",
    "import random\n",
    "import os\n",
    "import gc\n",
    "import torch\n",
    "from pathlib import Path\n",
    "from diffusers import StableDiffusion3Pipeline\n",
    "from huggingface_hub import scan_cache_dir\n",
    "\n",
    "print(\"=\" * 80)\n",
    "print(\"涓嬭浇妯″瀷鏉冮噸\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "# 閰嶇疆妯″瀷缂撳瓨鐩綍\n",
    "MODEL_CACHE_DIR = WORK_DIR / \"huggingface_cache\"\n",
    "MODEL_CACHE_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "os.environ[\"HF_HOME\"] = str(MODEL_CACHE_DIR)\n",
    "os.environ[\"HUGGINGFACE_HUB_CACHE\"] = str(MODEL_CACHE_DIR)\n",
    "\n",
    "print(f\"\\n妯″瀷缂撳瓨鐩綍锛歿MODEL_CACHE_DIR}\")\n",
    "print(f\"  鍙敤纾佺洏绌洪棿锛歿os.statvfs(str(MODEL_CACHE_DIR)).f_bavail * os.statvfs(str(MODEL_CACHE_DIR)).f_frsize / (1024**3):.1f} GB\")\n",
    "\n",
    "print(\"\\n妫€鏌?Hugging Face 璁よ瘉...\")\n",
    "try:\n",
    "    from huggingface_hub import HfApi\n",
    "    api = HfApi()\n",
    "    try:\n",
    "        user_info = api.whoami()\n",
    "        print(f\"  鉁?宸茶璇侊細{user_info.get('name', 'Unknown')}\")\n",
    "    except:\n",
    "        print(\"  鈩?鏈璇侊紙浣跨敤鍖垮悕璁块棶锛塡")\n",
    "except ImportError:\n",
    "    print(\"  鈿?huggingface_hub 鏈畨瑁匼")\n",
    "\n",
    "# 涓嬭浇 Stable Diffusion 3.5 妯″瀷\n",
    "print(\"\\n\" + \"=\" * 80)\n",
    "print(\"涓嬭浇 Stable Diffusion 3.5 妯″瀷\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "MODEL_ID = \"stabilityai/stable-diffusion-3.5-medium\"\n",
    "\n",
    "# 妫€鏌ユā鍨嬫槸鍚﹀凡缂撳瓨\n",
    "def check_model_cached(model_id):\n",
    "    \"\"\"\n",
    "    鍔熻兘锛氭鏌ユā鍨嬫槸鍚﹀凡鍦ㄧ紦瀛樹腑銆俓n",
    "    \n",
    "    Check if model is already cached locally.\n",
    "    \n",
    "    Args:\n",
    "        model_id: Model identifier.\n",
    "        \n",
    "    Returns:\n",
    "        Boolean indicating if model is cached.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        cache_info = scan_cache_dir()\n",
    "        for repo in cache_info.repos:\n",
    "            if model_id in repo.repo_id:\n",
    "                return True\n",
    "        return False\n",
    "    except Exception:\n",
    "        return False\n",
    "\n",
    "if check_model_cached(MODEL_ID):\n",
    "    print(f\"鉁?妯″瀷宸茬紦瀛橈細{MODEL_ID}\")\n",
    "    print(\"  璺宠繃涓嬭浇\")\n",
    "else:\n",
    "    print(f\"\\n鈴?妯″瀷鏈紦瀛橈紝寮€濮嬩笅杞斤細{MODEL_ID}\")\n",
    "    print(\"   杩欏彲鑳介渶瑕?5-15 鍒嗛挓锛堝彇鍐充簬缃戠粶锛塡")\n",
    "    \n",
    "    try:\n",
    "        # 涓嬭浇妯″瀷鍒版湰鍦扮紦瀛橈紙浠呯紦瀛橈紝涓嶅姞杞藉埌鍐呭瓨锛塡n",
    "        print(\"  涓嬭浇涓?..\")\n",
    "        \n",
    "        # 娉ㄦ剰锛歋tableDiffusion3Pipeline 涓嶆敮鎸?device_map=\"cpu\"\n",
    "        # 浠呮墽琛屾ā鍨嬩笅杞藉拰缂撳瓨锛屼娇鐢ㄥ钩琛＄瓥鐣ラ伩鍏?OOM\n",
    "        pipeline = StableDiffusion3Pipeline.from_pretrained(\n",
    "            MODEL_ID,\n",
    "            cache_dir=str(MODEL_CACHE_DIR),\n",
    "            torch_dtype=torch.float16,  # 浣跨敤 float16 鑺傜渷鏄惧瓨\n",
    "            device_map=\"balanced\"  # 浣跨敤骞宠　绛栫暐锛堣嚜鍔ㄥ垎閰嶅埌鍙敤璁惧锛塡n",
    "        )\n",
    "        print(\"  鉁?妯″瀷涓嬭浇瀹屾垚\")\n",
    "        \n",
    "        # 楠岃瘉妯″瀷鍔犺浇\n",
    "        print(\"  楠岃瘉妯″瀷缁撴瀯...\")\n",
